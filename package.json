{
  "name": "runningl-es",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "dev:mobile": "pnpm --filter mobile start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "react-native-screens": "~3.31.1"
    }
  }
}
